{
	"compilerOptions": {
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths" : {
			"@src/*": ["./src/*"],
			"@render/*": ["./src/render/*"],
			"@utils/*": ["./src/utils/*"],
		},
		"strict": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"types": [
			"obsidian"
		],
		"lib": [
			"DOM",
			"ES2018"
		],
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	]
}