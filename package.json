{
  "name": "activity-tracker",
  "version": "1.0.0",
  "description": "Customizable activity heatmap with GitHub-style and yearly views",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs",
    "watch:css": "sass -w --poll scss/main.scss:styles.css --no-source-map",
    "format": "biome format src",
    "format:fix": "biome format src --write",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "commit": "git add . && git commit"
  },
  "keywords": [],
  "author": "Jasperwoodchuck",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "obsidian": "^1.12.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/luxon": "^3.7.1",
    "esbuild": "^0.27.4",
    "sass": "^1.98.0",
    "typescript": "^6.0.2"
  }
}
